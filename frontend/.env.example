# ─────────────────────────────────────────────────────────────────
#  Lexume Frontend – Environment Variables
#  Copy this file to .env.local and fill in values.
#  Never commit the actual .env.local file.
# ─────────────────────────────────────────────────────────────────

# URL of the Lexume backend API
# Local dev: http://localhost:8000
# Standalone backend (e.g. Fly.io): https://your-api.fly.dev
# Vercel multi-service deploy (see root vercel.json): leave this EMPTY -
# same-origin /api/* calls get routed to the backend service by the
# rewrites in vercel.json, no separate backend URL needed.
NEXT_PUBLIC_API_URL=http://localhost:8000
